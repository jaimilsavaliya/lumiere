{
    "compilerOptions": {
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "incremental": true,
        "isolatedModules": true,
        "lib": ["ESNext"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "build",
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "removeComments": true,
        "resolveJsonModule": true,
        "rootDir": "src",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "ESNext",
        "verbatimModuleSyntax": true
    },
    "include": ["src"],
    "exclude": ["src/frontend/**/*", "src/**/*.test.ts"]
}
